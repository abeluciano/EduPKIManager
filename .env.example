# EduPKIManager local/demo configuration.
# Copy this file to .env and change secrets before using a shared or production-like environment.

POSTGRES_DB=edupki
POSTGRES_USER=edupki
POSTGRES_PASSWORD=change-me-postgres-password

CA_KEY_PASSWORD=change-me-ca-key-password
DJANGO_SECRET_KEY=change-me-django-secret-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=edupkimanager.com,www.edupkimanager.com,localhost,127.0.0.1

EDUPKI_ADMIN_PASSWORD=change-me-admin-password
EDUPKI_USER_PASSWORD=change-me-user-password

EDUPKI_PUBLIC_BASE_URL=https://edupkimanager.com/api
EDUPKI_TLS_HOSTNAME=edupkimanager.com
EDUPKI_TLS_SANS=edupkimanager.com,www.edupkimanager.com,localhost,127.0.0.1

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://edupkimanager.com,http://www.edupkimanager.com,http://edupkimanager.com:3000,http://www.edupkimanager.com:3000,https://edupkimanager.com,https://www.edupkimanager.com,https://localhost
CSRF_TRUSTED_ORIGINS=https://edupkimanager.com,https://www.edupkimanager.com,http://edupkimanager.com,http://www.edupkimanager.com

EDUPKI_API_PORT=8000
EDUPKI_HTTP_PORT=80
EDUPKI_HTTPS_PORT=443
EDUPKI_FRONTEND_PORT=3000
CRL_REFRESH_SECONDS=300
